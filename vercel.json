{
  "rewrites": [
    { "source": "/.well-known/agent-card.json",  "destination": "/.well-known/agent.json" },
    { "source": "/api/agent-card",               "destination": "/api/agent?agent-card=true" }
  ],
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "functions": {
    "api/agent.ts":       { "maxDuration": 300 },
    "api/verify.ts":      { "maxDuration": 300 },
    "api/deep-check.ts":  { "maxDuration": 300 },
    "api/batch-verify.ts":{ "maxDuration": 300 },
    "api/mcp.ts":         { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/daily-summary", "schedule": "0 23 * * *" },
    { "path": "/api/cron-check-deps", "schedule": "0 23 * * 0" }
  ]
}
